<!-- Category Hero Begin -->
<section class="category-hero set-bg" data-setbg="img/banner/banner-3.jpg">
    <div class="container">
        <div class="row kids">
            <div class="col-lg-12">
                <div class="category-hero__text">
                    <h2>Men's Collection</h2>
                    <p>Discover the latest trends in men's fashion</p>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Category Hero End -->

<!-- Breadcrumb Begin -->
<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a href="/"><i class="fa-solid fa-house"></i> Home</a>
                    <span>Men's</span>
                </div>
            </div>
        </div>
    </div>
</div>
