            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/woman">Women's</a></li>
                <li class="active"><a href="/men">Men's</a></li>
                <li><a href="/kids">Kid's</a></li>
                <li><a href="/shop">Shop</a></li>
                <li><a href="#">Pages</a>
