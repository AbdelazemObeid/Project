@{
    Layout = "~/Views/Shared/user/_userlayout.cshtml";
}

@section breadCrumb {
    <div class="col-xl-6 col-lg-7">
        <nav class="header__menu">
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/women">Women's</a></li>
                <li><a href="/men">Men's</a></li>
                <li><a href="/kids">Kid's</a></li>
                <li><a href="/shop">Shop</a></li>
                <li>
                    <a href="#">Pages</a>
                    <ul class="dropdown">
                        <li><a href="/product_details">Product Details</a></li>
                        <li><a href="/shop-cart">Shop Cart</a></li>
                        <li><a href="/checkout">Checkout</a></li>
                    </ul>
                </li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </nav>
    </div>
}

<!-- Breadcrumb Begin -->
<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a href="/Home/Index"><i class="fa-solid fa-house"></i> Home</a>
                    <span>Login</span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->

<!-- Login Section Begin -->
<section class="login spad" style="display: flex; justify-content: center; padding: 100px 0;">
    <div class="login-container" style="background-color: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 8px 20px rgba(0,0,0,0.1); width: 100%; max-width: 400px; text-align: center;">
        <h2 style="margin-bottom: 30px; color: #111; font-family: 'Montserrat', sans-serif; font-weight: 700;">Sign In</h2>
        <form id="loginForm">
            <input type="email" id="email" placeholder="youremail@example.com" required style="width: 100%; padding: 12px 15px; margin: 10px 0; border: 1px solid #e1e1e1; border-radius: 4px; outline: none; font-size: 14px; font-family: 'Montserrat', sans-serif;">
            <input type="password" id="password" placeholder="Password" required style="width: 100%; padding: 12px 15px; margin: 10px 0; border: 1px solid #e1e1e1; border-radius: 4px; outline: none; font-size: 14px; font-family: 'Montserrat', sans-serif;">
            <button type="submit" class="site-btn" style="width: 100%; margin-top: 10px; border-radius: 4px;">Sign In</button>
        </form>
        <a href="#" class="forgot" style="display: block; margin-top: 15px; color: #666; text-decoration: none; font-size: 14px; font-family: 'Montserrat', sans-serif;">Forgot Password?</a>
        <p class="signup" style="margin-top: 20px; font-size: 14px; font-family: 'Montserrat', sans-serif; color: #666;">Don't have an account? <a href="/signup" style="color: #ca1515; text-decoration: none; font-weight: 600;">Create Account</a></p>
    </div>
</section>
<!-- Login Section End -->

<script src="login.js"></script>
