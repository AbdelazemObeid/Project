@model project_MVC.Models.Product
@{
    ViewData["Title"] = "Product Details";
    ViewData["ActivePage"] = "Products";
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}

<section class="content-section active">
    <div class="section-header flex-between">
        <h1>Product Details</h1>
        <a href="/admin/products" class="btn btn-secondary"><i class="fa-solid fa-arrow-left"></i> Back to Products</a>
    </div>
    <div class="card">
        <div class="card-body">
            <div class="row">

                <div class="col-md-8">
                    <h2>@Model.name</h2>
                    <h4 class="text-primary mb-3">@Model.price EGP</h4>
                    
                    <table class="table table-bordered mt-4">
                        <tbody>
                            <tr>
                                <th style="width: 30%">ID</th>
                                <td>#@Model.id</td>
                            </tr>
                            <tr>
                                <th>Category</th>
                                <td><span class="badge badge-primary">@(Model.category?.name ?? "No Category")</span></td>
                            </tr>
                            <tr>
                                <th>Color</th>
                                <td>@Model.color</td>
                            </tr>
                            <tr>
                                <th>Size</th>
                                <td>@Model.size</td>
                            </tr>
                            <tr>
                                <th>Quantity Available</th>
                                <td>@Model.quantity</td>
                            </tr>
                            <tr>
                                <th>Description</th>
                                <td>@Model.description</td>
                            </tr>
                        </tbody>
                    </table>
                    
                    <div class="mt-4">
                        <a href="/admin/products/edit/@Model.id" class="btn btn-warning"><i class="fa-solid fa-pen"></i> Edit</a>
                        <form action="/admin/products/delete/@Model.id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product?')">
                            <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash"></i> Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
