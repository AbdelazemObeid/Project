@model project_MVC.Models.Product
@{
    ViewData["Title"] = "Edit Product";
    ViewData["ActivePage"] = "Products";
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}

<section class="content-section active">
    <div class="section-header">
        <h1>Edit Product: @Model.name</h1>
    </div>
    <div class="card">
        <div class="card-body">
            <form action="/admin/products/edit/@Model.id" method="post">
                <input type="hidden" name="id" value="@Model.id">
                <div class="form-group">
                    <label>Product Name</label>
                    <input type="text" name="name" class="form-control" value="@Model.name" required>
                </div>
                <div class="form-group">
                    <label asp-for="price">Price</label>
                    <input type="number" name="price" class="form-control" value="@Model.price" required>
                </div>
                <div class="form-group">
                    <label>Quantity</label>
                    <input type="number" name="quantity" class="form-control" value="@Model.quantity" required>
                </div>

                <div class="form-group">
                    <label>Category</label>
                    <select name="category_id" class="form-control">
                        @foreach (var cat in (List<project_MVC.Models.Category>)ViewBag.Categories)
                        {
                            <option value="@cat.id" selected="@(cat.id == Model.category_id)">@cat.name</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" class="form-control" rows="4">@Model.description</textarea>
                </div>
                <div class="form-group">
                    <label>Color</label>
                    <input type="text" name="color" class="form-control" value="@Model.color">
                </div>
                <div class="form-group">
                    <label>Size</label>
                    <input type="text" name="size" class="form-control" value="@Model.size">
                </div>
                <button type="submit" class="btn btn-primary">Update Product</button>
                <a href="/admin/products" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</section>
