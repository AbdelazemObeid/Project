@model List<Product>
@{
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}
<div class="sidebar">
    <h2 class="logo"><i class="fa-solid fa-shield-halved"></i> Admin Panel</h2>
    <a href="/admin"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
    <a href="/admin/products" class="active"><i class="fa-solid fa-box"></i> Products</a>
    <a href="/admin/user"><i class="fa-solid fa-users"></i> Users</a>
    <a href="/" id="log"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<div class="main">
    @if (TempData["message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert" style="border-radius: 10px;">
            <div class="d-flex align-items-center">
                <i class="fa fa-check-circle me-2" style="font-size: 60px;text-align:center; background-color: #2563eb; color: white; border-radius: 20px; padding: 10px;"><strong>@TempData["message"]</strong></i>
            </div>
        </div>
    }
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
        <h1><i class="fa-solid fa-boxes-stacked"></i> Products Management</h1>
        <a href="/admin/products/add" class="btn"><i class="fa-solid fa-plus"></i> Add New Product</a>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>category</th>
                    <th>sup_category</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td class="product-info">
                            <i class="fa-solid fa-tag icon-tag"></i> @product.name
                        </td>
                        <td><span class="price-text">@product.price</span></td>
                        <td><span class="badge">@product.category.name</span></td>
                        <td><span class="badge">@product.sup_category.Name</span></td>
                        <td>
                            <div class="action-group">
                                <a href="/admin/products/@product.id" class="btn-action btn-view" title="View"><i class="fa-solid fa-eye"></i></a>
                                <a href="/admin/products/edit/@product.id" class="btn-action btn-edit" title="Edit"><i class="fa-solid fa-pen"></i></a>
                                <a href="/admin/products/delete/@product.id" class="btn-action btn-delete" title="Delete"><i class="fa-solid fa-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>