@model List<project_MVC.Models.User>
@{
    ViewData["Title"] = "Manage Users";
    ViewData["ActivePage"] = "Users";
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}

<section class="content-section active">
    <div class="section-header flex-between">
        <div>
            <h1>Manage Users</h1>
        </div>
        <a href="/admin/users/create" class="btn btn-primary"><i class="fa-solid fa-user-plus"></i> Add User</a>
    </div>
    <div class="card">
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>#@u.id</td>
                            <td>@u.name</td>
                            <td>@u.email</td>
                            <td>@u.role</td>
                            <td>
                                <a href="/admin/users/details/@u.id" class="btn-icon btn-info" style="margin-right: 5px; color: white; background: #17a2b8; padding: 8px; border-radius: 4px; text-decoration: none;"><i class="fa-solid fa-eye"></i></a>
                                <a href="/admin/users/edit/@u.id" class="btn-icon btn-edit" style="margin-right: 5px;"><i class="fa-solid fa-pen"></i></a>
                                <form action="/admin/users/delete/@u.id" method="post" style="display:inline;" onsubmit="return confirm('Delete user?')">
                                    <button type="submit" class="btn-icon btn-delete" style="cursor:pointer; border:none; background:none;">
                                        <i class="fa-solid fa-trash" style="color:white; background:#ff4d4d; padding:8px; border-radius:4px;"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
