@{
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}
<div class="sidebar">
    <h2 class="logo"><i class="fa-solid fa-shield-halved"></i> Admin Panel</h2>
    <a href="/admin"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
    <a href="/admin/products"><i class="fa-solid fa-box"></i> Products</a>
    <a href="/admin/user" class="active"><i class="fa-solid fa-users"></i> Users</a>
    <a href="/" id="log"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<div class="main-content">
    <div class="header-section">
        <a href="/admin/user" class="back-link">
            <i class="fa-solid fa-arrow-left"></i> Back to Users
        </a>
        <h1 class="page-title"><i class="fa-solid fa-user-plus"></i> Create New Account</h1>
    </div>

    <div class="form-card">
        <form id="addUserForm" method="post">
            <div class="form-grid">

                <div class="form-group">
                    <label>Full Name</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-user field-icon"></i>
                        <input type="text" placeholder="John Doe" name="name" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Email Address</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-envelope field-icon"></i>
                        <input type="email" placeholder="name@company.com" name="email" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-lock field-icon"></i>
                        <input type="password" placeholder="••••••••" name="password" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <div class="input-wrapper">
                        <i class="fa-solid fa-phone field-icon"></i>
                        <input type="text" placeholder="01*********" name="phone_number">
                    </div>
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select class="form-select" name="role" required>
                        <option value="" disabled selected>Select Role</option>
                        <option value="user">User</option>
                        <option value="saller">Saller</option>
                        <option value="admin">Administrator</option>
                    </select>
                </div>
            </div>
            <div class="upload-area">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <p>Click to upload profile picture or drag and drop</p>
                <input type="file" hidden id="profilePic">
            </div>
            <div class="form-actions">
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i> Create Account
                </button>
                <button type="reset" class="btn-reset">Clear</button>
            </div>
        </form>
    </div>
</div>