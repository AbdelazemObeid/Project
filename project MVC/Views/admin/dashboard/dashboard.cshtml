@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/admin/_adminlayout.cshtml";
}

<div class="section-header">
    <h1>Dashboard Overview</h1>
    <p>Welcome back! Here's what's happening with your store today.</p>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon bg-primary">
            <i class="fa-solid fa-box-open"></i>
        </div>
        <div class="stat-details">
            <h3>Total Products</h3>
            <p class="stat-num">@ViewBag.ProductsCount</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-warning">
            <i class="fa-solid fa-users"></i>
        </div>
        <div class="stat-details">
            <h3>Total Users</h3>
            <p class="stat-num">@ViewBag.UsersCount</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-success">
            <i class="fa-solid fa-cart-shopping"></i>
        </div>
        <div class="stat-details">
            <h3>Total Orders</h3>
            <p class="stat-num">@ViewBag.OrdersCount</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon bg-danger">
            <i class="fa-solid fa-envelope"></i>
        </div>
        <div class="stat-details">
            <h3>Total Messages</h3>
            <p class="stat-num">@ViewBag.ContactsCount</p>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2>Quick Actions</h2>
    </div>
    <div class="card-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
            <a href="/admin/products/create" class="btn btn-primary" style="justify-content: center;">
                <i class="fa-solid fa-plus"></i> Add New Product
            </a>
            <a href="/admin/users/create" class="btn btn-primary" style="background: var(--sidebar-bg); justify-content: center;">
                <i class="fa-solid fa-user-plus"></i> Add New User
            </a>
            <a href="/admin/statistics" class="btn btn-primary" style="background: var(--info); justify-content: center;">
                <i class="fa-solid fa-chart-simple"></i> Detailed Stats
            </a>
        </div>
    </div>
</div>
